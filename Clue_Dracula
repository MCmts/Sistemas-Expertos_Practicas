def abrir_cuaderno():

    global cuaderno_abierto

    if cuaderno_abierto:
        return

    cuaderno_abierto = True

    ventana = tk.Toplevel(root)

    ventana.title("Cuaderno")

    ventana.geometry("500x700")

    ventana.config(bg="#1b1b1b")

    tk.Label(
        ventana,
        text="CUADERNO",
        bg="#1b1b1b",
        fg="gold",
        font=("Arial", 24, "bold")
    ).pack(pady=20)

    tk.Label(
        ventana,
        text="SOSPECHOSOS",
        bg="#1b1b1b",
        fg="white",
        font=("Arial", 18, "bold")
    ).pack()

    for p in personajes:

        barra = "█" * p["sospecha"]

        texto = f'{p["nombre"]} {barra}'

        tk.Label(
            ventana,
            text=texto,
            bg="#1b1b1b",
            fg="red",
            font=("Arial", 14)
        ).pack(anchor="w", padx=40)

    def cerrar():

        global cuaderno_abierto

        cuaderno_abierto = False

        ventana.destroy()

    ventana.protocol(
        "WM_DELETE_WINDOW",
        cerrar
    )

# =========================================================
# ACUSAR
# =========================================================

def acusar():

    ventana = tk.Toplevel(root)

    ventana.title("Acusación")

    ventana.geometry("400x350")

    ventana.config(bg="#111111")

    sospechoso_var = tk.StringVar()

    arma_var = tk.StringVar()

    lugar_var = tk.StringVar()

    tk.Label(
        ventana,
        text="SOSPECHOSO",
        bg="#111111",
        fg="white"
    ).pack()

    ttk.Combobox(
        ventana,
        textvariable=sospechoso_var,
        values=[
            p["nombre"]
            for p in personajes
        ]
    ).pack(pady=10)

    tk.Label(
        ventana,
        text="ARMA",
        bg="#111111",
        fg="white"
    ).pack()

    ttk.Combobox(
        ventana,
        textvariable=arma_var,
        values=armas
    ).pack(pady=10)

    tk.Label(
        ventana,
        text="LUGAR",
        bg="#111111",
        fg="white"
    ).pack()

    ttk.Combobox(
        ventana,
        textvariable=lugar_var,
        values=[
            h["nombre"]
            for h in habitaciones
        ]
    ).pack(pady=10)

    def confirmar():

        correcto = (

            sospechoso_var.get()
            ==
            culpable["nombre"]

            and

            arma_var.get()
            ==
            arma_real

            and

            lugar_var.get()
            ==
            lugar_real["nombre"]
        )

        if correcto:

            messagebox.showinfo(
                "VICTORIA",
                "Resolviste el asesinato."
            )

        else:

            messagebox.showerror(
                "ERROR",
                "La acusación fue incorrecta."
            )

    tk.Button(
        ventana,
        text="CONFIRMAR",
        command=confirmar,
        bg="darkred",
        fg="white"
    ).pack(pady=20)


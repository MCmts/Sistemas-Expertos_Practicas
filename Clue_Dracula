# NAVEGACION
# =========================================================

def siguiente():

    global indice

    indice += 1

    if indice >= len(habitaciones):
        indice = 0

    cargar_habitacion()

def anterior():

    global indice

    indice -= 1

    if indice < 0:
        indice = len(habitaciones) - 1

    cargar_habitacion()


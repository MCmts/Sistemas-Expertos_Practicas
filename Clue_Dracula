def cargar_habitacion():

    global dialogo_actual
    global fase
    global fondo_tk

    canvas.delete("all")

    habitacion = habitaciones[indice]

    # =====================================================
    # VISITAS
    # =====================================================

    if (
        habitacion["nombre"]
        not in habitaciones_visitadas
    ):

        habitaciones_visitadas.append(
            habitacion["nombre"]
        )

    # =====================================================
    # FASE 2
    # =====================================================

    if (
        len(habitaciones_visitadas)
        ==
        len(habitaciones)

        and

        fase == 1
    ):

        fase = 2

        messagebox.showinfo(
            "FASE 2",
            "Tus poderes vampíricos despertaron."
        )

    # =====================================================
    # FONDO
    # =====================================================

    fondo = Image.open(
        habitacion["imagen"]
    )

    fondo = fondo.resize(
        (ANCHO, ALTO)
    )

    fondo_tk = ImageTk.PhotoImage(
        fondo
    )

    canvas.create_image(
        0,
        0,
        anchor="nw",
        image=fondo_tk
    )

    # =====================================================
    # OVERLAY
    # =====================================================

    color_overlay = "black"

    if fase == 2:
        color_overlay = "#220000"

    canvas.create_rectangle(
        0,
        0,
        ANCHO,
        ALTO,
        fill=color_overlay,
        stipple="gray25"
    )

    # =====================================================
    # PANEL DERECHO
    # =====================================================

    canvas.create_rectangle(
        1040,
        0,
        1280,
        720,
        fill="#111111",
        outline="darkred",
        width=4
    )

    # =====================================================
    # TITULO
    # =====================================================

    canvas.create_text(
        500,
        40,
        text=habitacion["nombre"],
        fill="white",
        font=("Times New Roman", 30, "bold")
    )

    # =====================================================
    # PERSONAJE
    # =====================================================

    personaje = habitacion["personaje"]

    canvas.create_rectangle(
        20,
        560,
        500,
        690,
        fill="#111111",
        outline="darkred",
        width=3
    )

    canvas.create_text(
        50,
        595,
        anchor="w",
        text=personaje["nombre"],
        fill="gold",
        font=("Arial", 18, "bold")
    )

    canvas.create_text(
        50,
        625,
        anchor="w",
        text=personaje["profesion"],
        fill="white",
        font=("Arial", 12)
    )

    dialogo = random.choice(
        personaje["dialogos"]
    )

    dialogo_actual = canvas.create_text(
        50,
        660,
        anchor="w",
        width=420,
        text=f'"{dialogo}"',
        fill="#cccccc",
        font=("Arial", 10, "italic")
    )

    root.after(
        2000,
        lambda: canvas.delete(dialogo_actual)
    )

    # =====================================================
    # EVIDENCIA
    # =====================================================

    canvas.create_text(
        850,
        100,
        text=f"🔪 {habitacion['arma']}",
        fill="red",
        font=("Arial", 18, "bold")
    )

    # =====================================================
    # PISTA OCULTA
    # =====================================================

    pista = habitacion["pista_oculta"]

    if (
        fase == 2
        and
        not pista["encontrada"]
    ):

        canvas.create_oval(
            pista["x"],
            pista["y"],
            pista["x"] + 20,
            pista["y"] + 20,
            fill="darkred",
            outline="red"
        )

# =========================================================
# CLICK MAPA
# =========================================================

def click_mapa(event):

    if fase != 2:
        return

    habitacion = habitaciones[indice]

    pista = habitacion["pista_oculta"]

    if pista["encontrada"]:
        return

    if (

        abs(event.x - pista["x"]) < 40

        and

        abs(event.y - pista["y"]) < 40
    ):

        pista["encontrada"] = True

        personaje = habitacion["personaje"]

        personaje["sospecha"] += random.randint(1, 3)

        messagebox.showinfo(
            "PISTA",
            f"Encontraste:\n{pista['nombre']}"
        )

        cargar_habitacion()

# =========================================================
# INVESTIGAR
# =========================================================

def investigar():

    if fase == 1:

        messagebox.showinfo(
            "EXPLORACIÓN",
            "Primero explora todas las habitaciones."
        )

        return

    habitacion = habitaciones[indice]

    personaje = habitacion["personaje"]

    personaje["sospecha"] += random.randint(1, 3)

    pistas = [

        "Escuchaste un susurro.",

        "Tu visión vampírica detectó miedo.",

        "Sentiste olor a sangre.",

        "Algo oscuro observa esta habitación.",

        "El sospechoso parece nervioso."
    ]

    pista = random.choice(pistas)

    messagebox.showinfo(
        "INVESTIGACIÓN",
        pista
    )

# =========================================================
# INTERROGAR
# =========================================================

def interrogar():

    if fase != 2:

        messagebox.showinfo(
            "BLOQUEADO",
            "Completa la exploración primero."
        )

        return

    habitacion = habitaciones[indice]

    personaje = habitacion["personaje"]

    ventana = tk.Toplevel(root)

    ventana.title("Interrogatorio")

    ventana.geometry("500x400")

    ventana.config(bg="#111111")

    tk.Label(
        ventana,
        text=f"Interrogando a {personaje['nombre']}",
        bg="#111111",
        fg="gold",
        font=("Arial", 18, "bold")
    ).pack(pady=20)

    for pregunta in personaje["preguntas"]:

        def responder(p=pregunta):

            respuesta = personaje["preguntas"][p]

            personaje["sospecha"] += random.randint(0, 2)

            messagebox.showinfo(
                p,
                respuesta
            )

        tk.Button(
            ventana,
            text=pregunta,
            command=responder,
            bg="#222",
            fg="white"
        ).pack(
            fill="x",
            padx=20,
            pady=5
        )

